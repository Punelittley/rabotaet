# Скопируйте в файл .env в корне проекта и подставьте значения.
# ВК: Управление сообществом → Настройки → Работа с API → Создать ключ
# (нужны права: сообщения сообщества, или «полный доступ» для теста).

# Токен сообщества (обязательно для пересылки чата с сайта в ВК)
VK_GROUP_TOKEN=

# Кому слать входящие с сайта: peer_id личного диалога с сообществом.
# Часто это ваш vk id (положительное число), если пишете сообществу от своего аккаунта.
# Либо оставьте пустым и привяжите через Callback API командой /bind в диалоге.
VK_SUPPORT_PEER_ID=

# Секрет Callback API (должен совпадать с полем в настройках Callback)
VK_CALLBACK_SECRET=

# Строка подтверждения Callback — точное значение из блока «Строка, которую должен вернуть сервер»
VK_CONFIRMATION_TOKEN=

# Опционально: id сообщества из JSON confirmation (group_id), если хотите лишний контроль
# VK_GROUP_ID=
